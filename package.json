{
  "name": "sassy-but-gui",
  "displayName": "Sassy, but GUI",
  "publisher": "gesslar",
  "version": "1.0.0",
  "description": "Sassy but GUI",
  "main": "./src/ritual-sacrifice-to-cjs.cjs",
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:yaml"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gesslar/sassy-but-gui.git"
  },
  "homepage": "https://github.com/gesslar/sassy-but-gui#readme",
  "categories": [
    "Other",
    "Themes"
  ],
  "keywords": [],
  "author": {
    "name": "gesslar",
    "url": "https://github.com/gesslar/sassy-but-gui"
  },
  "license": "Unlicense",
  "type": "module",
  "scripts": {
    "update": "npx npm-check-updates -u && npm install",
    "pr": "gt submit -p --ai",
    "lint": "eslint src/",
    "package": "npx @vscode/vsce package --no-dependencies --skip-license -o vsix",
    "publish:vsce": "npm run package && xdg-open https://marketplace.visualstudio.com/manage/publishers/gesslar",
    "publish:ovsx": "npm run package && xdg-open https://open-vsx.org/user-settings/extensions",
    "patch": "npm version patch",
    "minor": "npm version minor",
    "major": "npm version major"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "dependencies": {
    "@gesslar/sassy": "^5.12.0",
    "@gesslar/toolkit": "^4.1.0",
    "@gesslar/vscode-theme-schema": "^1.0.0",
    "@vscode-elements/elements": "^2.5.1",
    "@vscode/codicons": "^0.0.44",
    "@vscode/vsce": "^3.7.1"
  },
  "devDependencies": {
    "@gesslar/uglier": "^2.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3"
  },
  "contributes": {
    "configurationDefaults": {
      "files.associations": {
        "*.sassy.yaml": "yaml"
      }
    },
    "commands": [
      {
        "command": "sassy.showPanel",
        "title": "Show Sassy Panel",
        "icon": "$(color-mode)"
      },
      {
        "command": "sassy.buildTheme",
        "title": "Build Theme",
        "icon": "$(export)"
      },
      {
        "command": "sassy.enableAutoBuild",
        "title": "Enable Auto-Build",
        "icon": "$(sync)"
      },
      {
        "command": "sassy.disableAutoBuild",
        "title": "Disable Auto-Build",
        "icon": "$(sync-ignored)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "sassy.showPanel",
          "when": "resourceFilename =~ /\\.sassy\\.yaml$/",
          "group": "navigation"
        },
        {
          "command": "sassy.buildTheme",
          "when": "resourceFilename =~ /\\.sassy\\.yaml$/",
          "group": "navigation"
        },
        {
          "command": "sassy.enableAutoBuild",
          "when": "resourceFilename =~ /\\.sassy\\.yaml$/ && !sassy.autoBuildActive",
          "group": "navigation"
        },
        {
          "command": "sassy.disableAutoBuild",
          "when": "resourceFilename =~ /\\.sassy\\.yaml$/ && sassy.autoBuildActive",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "sassy.buildTheme",
          "when": "resourceFilename =~ /\\.sassy\\.yaml$/",
          "group": "sassy"
        },
        {
          "command": "sassy.showPanel",
          "when": "resourceFilename =~ /\\.sassy\\.yaml$/",
          "group": "sassy"
        }
      ]
    }
  }
}
