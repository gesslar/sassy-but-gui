{
  "name": "sassy-but-gui",
  "displayName": "Sassy, but GUI",
  "publisher": "gesslar",
  "version": "1.0.0",
  "description": "Sassy but GUI",
  "main": "./src/ritual-sacrifice-to-cjs.cjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gesslar/sassy-but-gui.git"
  },
  "homepage": "https://github.com/gesslar/sassy-but-gui#readme",
  "categories": [
    "Other",
    "Themes"
  ],
  "keywords": [],
  "author": {
    "name": "gesslar",
    "url": "https://github.com/gesslar/sassy-but-gui"
  },
  "license": "Unlicense",
  "type": "module",
  "scripts": {
    "update": "npx npm-check-updates -u && npm install",
    "pr": "gt submit -p --ai",
    "lint": "eslint src/",
    "package": "npx @vscode/vsce package --no-dependencies --skip-license -o vsix/",
    "publish:vsce": "npm run package && xdg-open https://marketplace.visualstudio.com/manage/publishers/gesslar",
    "publish:ovsx": "npm run package && xdg-open https://open-vsx.org/user-settings/extensions",
    "patch": "npm version patch",
    "minor": "npm version minor",
    "major": "npm version major"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "dependencies": {
    "@gesslar/sassy": "^4.5.1",
    "@gesslar/toolkit": "file:../toolkit",
    "@vscode/codicons": "^0.0.44",
    "@vscode/vsce": "^3.7.1"
  },
  "devDependencies": {
    "@gesslar/uglier": "^2.0.0",
    "eslint": "^10.0.2"
  },
  "contributes": {
    "commands": [
      {
        "command": "sassy.open",
        "title": "Open Sassy file",
        "icon": {
          "dark": "resources/double-s-white.svg",
          "light": "resources/double-s.svg"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "sassy.open",
          "group": "2_open@1"
        }
      ]
    }
  }
}
